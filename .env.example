# ── Deploy-time secrets ─────────────────────────────────────────────
# The Deploy to Cloudflare button reads this file and asks you for each
# value on its setup screen, storing them as encrypted Worker secrets.
# All three are copy-paste jobs — the setup guide walks every one.

# Supabase → Project Settings → API keys → the SECRET key (sb_secret_…).
# This is the Worker's key to your database. Treat it like a password.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_paste_yours_here

# Any long random string (30+ characters — mash the keyboard or use a
# password generator). Signs login sessions; rotating it logs you out
# everywhere. Nothing else ever needs to know it.
SESSION_SECRET=paste_a_long_random_string_here

# A Cloudflare API token so the app can manage its own API keys from the
# admin panel (no terminal, ever). Create it with two permissions:
#   Account → Account Settings → Read
#   Account → Secrets Store → Edit
CF_SECRETS_STORE_TOKEN=paste_your_cloudflare_api_token_here
